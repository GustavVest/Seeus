# === LLM API Configuration ===
# Supports any OpenAI-compatible API (OpenAI, Azure, Anthropic via proxy, etc.)
# Get your key at: https://platform.openai.com/api-keys
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# === Zep Cloud Memory Graph ===
# Free tier available at: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# === Optional: Boost LLM (for parallel acceleration) ===
# Only add these if you want to use a separate model for acceleration
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=your_base_url_here
# LLM_BOOST_MODEL_NAME=your_model_name_here
